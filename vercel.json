{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "build": {
    "env": {
      "VITE_SUPABASE_URL": "@vite_supabase_url",
      "VITE_SUPABASE_ANON_KEY": "@vite_supabase_anon_key",
      "VITE_STRIPE_PUBLISHABLE_KEY": "@vite_stripe_publishable_key",
      "VITE_ADMIN_EMAIL": "@vite_admin_email"
    }
  }
}
